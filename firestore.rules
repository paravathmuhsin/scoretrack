rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function authed() {
      return request.auth != null;
    }

    /** Read parent match doc — use only under matches/{mid}/… subpaths (not for listing matches). */
    function matchData(mid) {
      return get(/databases/$(database)/documents/matches/$(mid)).data;
    }

    /** Public score/events can be read without auth when the match is public. */
    function canAccessMatchSubcollection(mid) {
      return exists(/databases/$(database)/documents/matches/$(mid))
        && (
          matchData(mid).isPublic == true
          || (authed() && matchData(mid).createdBy == request.auth.uid)
        );
    }

    /** Signed-in user who created the match document. */
    function matchCreator(mid) {
      return authed()
        && exists(/databases/$(database)/documents/matches/$(mid))
        && matchData(mid).createdBy == request.auth.uid;
    }

    /** Tournament organiser (for cascade delete / listing linked matches). */
    function tournamentOrganiserForMatch(mid) {
      return authed()
        && exists(/databases/$(database)/documents/matches/$(mid))
        && matchData(mid).tournamentId != null
        && exists(/databases/$(database)/documents/tournaments/$(matchData(mid).tournamentId))
        && tournamentDoc(matchData(mid).tournamentId).data.createdBy == request.auth.uid;
    }

    /** Same as tournamentOrganiserForMatch but uses `resource` on the match document. */
    function tournamentOrganiserReadsThisMatch() {
      return authed()
        && resource.data.tournamentId != null
        && exists(/databases/$(database)/documents/tournaments/$(resource.data.tournamentId))
        && tournamentDoc(resource.data.tournamentId).data.createdBy == request.auth.uid;
    }

    function tournamentDoc(tid) {
      return get(/databases/$(database)/documents/tournaments/$(tid));
    }

    function tournamentExists(tid) {
      return exists(/databases/$(database)/documents/tournaments/$(tid));
    }

    function tournamentOwner(tid) {
      return authed()
        && tournamentExists(tid)
        && tournamentDoc(tid).data.createdBy == request.auth.uid;
    }

    function tournamentPublic(tid) {
      return tournamentExists(tid)
        && tournamentDoc(tid).data.isPublic == true;
    }

    /** teamCount is set only at create; updates must leave it unchanged (or absent on legacy docs). */
    function tournamentTeamCountImmutable() {
      return !resource.data.keys().hasAny(['teamCount'])
        ? !request.resource.data.keys().hasAny(['teamCount'])
        : request.resource.data.teamCount == resource.data.teamCount;
    }

    /** Squad doc must live under the organiser who links it into a tournament. */
    function userTeamDocExistsFor(uid, teamId) {
      return exists(/databases/$(database)/documents/users/$(uid)/teams/$(teamId));
    }

    function userTeamJoinInviteData(token) {
      return get(/databases/$(database)/documents/userTeamJoinInvites/$(token)).data;
    }

    /** Signed-in player may merge only profile mirror fields onto `playerCareerStats/{pid}` (doc id must match uid). */
    function careerSelfProfileWrite(pid) {
      return request.auth.uid == pid
        && string(request.resource.data.playerId) == string(pid)
        && (
          (
            !exists(/databases/$(database)/documents/playerCareerStats/$(pid))
            && request.resource.data.keys().hasOnly(['playerId', 'profileFullName', 'profileDisplayName', 'updatedAt'])
          )
          || (
            exists(/databases/$(database)/documents/playerCareerStats/$(pid))
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['profileFullName', 'profileDisplayName', 'updatedAt', 'playerId'])
          )
        );
    }

    /** Shareable join links under `userTeamJoinInvites/{token}` (token stored on `TeamDoc.joinInviteToken`). */
    match /userTeamJoinInvites/{token} {
      allow read: if authed();
      allow create: if authed()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.teamId is string
        && request.resource.data.teamName is string
        && request.resource.data.memberIds is list
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/teams/$(request.resource.data.teamId))
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if authed() && resource.data.ownerUid == request.auth.uid;
    }

    match /users/{uid} {
      allow read, write: if authed() && request.auth.uid == uid;

      match /teams/{teamId} {
        allow list: if authed() && request.auth.uid == uid;

        allow get: if authed() && request.auth.uid == uid
          || (
            authed()
            && resource.data.keys().hasAny(['joinInviteToken'])
            && resource.data.joinInviteToken is string
            && exists(/databases/$(database)/documents/userTeamJoinInvites/$(resource.data.joinInviteToken))
            && userTeamJoinInviteData(resource.data.joinInviteToken).ownerUid == uid
            && userTeamJoinInviteData(resource.data.joinInviteToken).teamId == teamId
          );

        allow create, delete: if authed() && request.auth.uid == uid;

        allow update: if authed() && request.auth.uid == uid
          || (
            authed()
            && request.auth.uid != uid
            && resource.data.keys().hasAny(['joinInviteToken'])
            && resource.data.joinInviteToken is string
            && exists(/databases/$(database)/documents/userTeamJoinInvites/$(resource.data.joinInviteToken))
            && userTeamJoinInviteData(resource.data.joinInviteToken).ownerUid == uid
            && userTeamJoinInviteData(resource.data.joinInviteToken).teamId == teamId
            && request.resource.data.joinInviteToken == resource.data.joinInviteToken
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players'])
            && request.resource.data.players.size() == resource.data.players.size() + 1
            && request.resource.data.players.size() <= 40
            && request.resource.data.players[resource.data.players.size()].playerId == request.auth.uid
            && request.resource.data.players[resource.data.players.size()].name is string
            && request.resource.data.players[resource.data.players.size()].name.size() > 0
          );
      }
    }

    /** Searchable display names for adding registered users to squads. */
    match /directoryUsers/{uid} {
      allow read: if authed();
      allow create, update: if authed() && request.auth.uid == uid;
      allow delete: if authed() && request.auth.uid == uid;
    }

    match /tournaments/{tid} {
      allow read: if resource.data.isPublic == true
        || (authed() && resource.data.createdBy == request.auth.uid);
      allow create: if authed()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.teamCount is int
        && request.resource.data.teamCount >= 2
        && request.resource.data.teamCount <= 64;
      allow update: if tournamentOwner(tid) && tournamentTeamCountImmutable();
      allow delete: if tournamentOwner(tid);

      match /linkedTeams/{linkId} {
        allow read: if tournamentPublic(tid) || tournamentOwner(tid);
        allow create: if tournamentOwner(tid)
          && request.resource.data.userTeamId is string
          && userTeamDocExistsFor(request.auth.uid, request.resource.data.userTeamId);
        allow update, delete: if tournamentOwner(tid);
      }

      match /groups/{gid} {
        allow read: if tournamentPublic(tid) || tournamentOwner(tid);
        allow create, update, delete: if tournamentOwner(tid);
      }

      match /teams/{teamId} {
        allow read: if tournamentPublic(tid) || tournamentOwner(tid)
          || (authed() && resource.data.organiserUid == request.auth.uid);
        allow create: if tournamentOwner(tid)
          && request.resource.data.organiserUid == tournamentDoc(tid).data.createdBy;
        allow update, delete: if tournamentOwner(tid)
          || (authed() && resource.data.organiserUid == request.auth.uid);
      }

      match /standings/{docId} {
        allow read: if tournamentPublic(tid) || tournamentOwner(tid);
        allow write: if tournamentOwner(tid);
      }

      match /stats/{docId} {
        allow read: if tournamentPublic(tid) || tournamentOwner(tid);
        allow write: if tournamentOwner(tid);
      }
    }

    match /matches/{mid} {
      /**
       * Public matches readable by anyone (for /live list & shared links).
       * Private matches: creator, or tournament organiser for that match's tournament.
       */
      allow read: if resource.data.isPublic == true
        || (authed() && resource.data.createdBy == request.auth.uid)
        || tournamentOrganiserReadsThisMatch();

      allow create: if authed() && request.resource.data.createdBy == request.auth.uid;

      allow update: if authed() && resource.data.createdBy == request.auth.uid;

      allow delete: if authed() && (
        resource.data.createdBy == request.auth.uid
        || (resource.data.tournamentId != null
            && exists(/databases/$(database)/documents/tournaments/$(resource.data.tournamentId))
            && tournamentDoc(resource.data.tournamentId).data.createdBy == request.auth.uid)
      );

      match /innings/{iid} {
        allow read: if canAccessMatchSubcollection(mid) || tournamentOrganiserForMatch(mid);
        allow create, update: if canAccessMatchSubcollection(mid);
        allow delete: if matchCreator(mid) || tournamentOrganiserForMatch(mid);
      }

      match /events/{eid} {
        allow read: if canAccessMatchSubcollection(mid) || tournamentOrganiserForMatch(mid);
        allow create: if authed() && matchData(mid).createdBy == request.auth.uid;
        allow update: if false;
        allow delete: if matchCreator(mid) || tournamentOrganiserForMatch(mid);
      }

      match /playerStats/{pid} {
        allow read: if canAccessMatchSubcollection(mid) || tournamentOrganiserForMatch(mid);
        allow create, update, delete: if matchCreator(mid);
      }
    }

    /**
     * Cross-match rollups (all completed XIs). Readable without auth so `/player/:uid` works when logged out
     * (mirrored names + aggregates are intended as shareable).
     */
    match /playerCareerStats/{pid} {
      allow read: if true;
      allow create, update: if authed() && (
        careerSelfProfileWrite(pid)
        || (
          request.resource.data.keys().hasAny(['sourceMatchId'])
          && request.resource.data.sourceMatchId is string
          && exists(/databases/$(database)/documents/matches/$(request.resource.data.sourceMatchId))
          && matchData(request.resource.data.sourceMatchId).createdBy == request.auth.uid
        )
        || (
          request.resource.data.keys().hasAny(['sourceTournamentId'])
          && request.resource.data.sourceTournamentId is string
          && tournamentExists(request.resource.data.sourceTournamentId)
          && tournamentDoc(request.resource.data.sourceTournamentId).data.createdBy == request.auth.uid
        )
      );
      allow delete: if false;
    }
  }
}
