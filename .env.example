# Public site URL for shared links (live match, overlay). Required in Capacitor builds.
VITE_PUBLIC_APP_URL=https://scoretrackonline.com

# Android APK direct download URL (GitHub Releases, raw GitHub, etc.).
# Leave unset to use the default GitHub releases/latest URL.
# Set to empty to hide the in-browser download prompt.
VITE_ANDROID_APK_URL=https://github.com/paravathmuhsin/scoretrack/raw/refs/heads/main/release/latest/ScoreTrack.apk

VITE_FIREBASE_API_KEY=
# Use scoretrackonline.com after Firebase Auth custom domain + DNS are verified.
# Fallback for local dev without custom domain: scoretrack-48b01.firebaseapp.com
VITE_FIREBASE_AUTH_DOMAIN=scoretrackonline.com
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
