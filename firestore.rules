rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function authed() {
      return request.auth != null;
    }

    /** Read parent match doc — use only under matches/{mid}/… subpaths (not for listing matches). */
    function matchData(mid) {
      return get(/databases/$(database)/documents/matches/$(mid)).data;
    }

    function matchRosterVisibleToAuth(mid) {
      return authed() && request.auth.uid in matchData(mid).rosterPlayerIds;
    }

    function matchParentSquadVisibleToAuth(mid) {
      return authed() && request.auth.uid in matchData(mid).parentTeamMemberIds;
    }

    function matchRosterVisibleOnResource() {
      return authed() && request.auth.uid in resource.data.rosterPlayerIds;
    }

    function matchParentSquadVisibleOnResource() {
      return authed() && request.auth.uid in resource.data.parentTeamMemberIds;
    }

    /** Public score/events can be read without auth when the match is public or has a live share link. */
    function matchHasLivePublicId(data) {
      return data.keys().hasAny(['publicId'])
        && data.publicId is string
        && data.publicId.size() > 0;
    }

    function canAccessMatchSubcollection(mid) {
      return exists(/databases/$(database)/documents/matches/$(mid))
        && (
          matchData(mid).isPublic == true
          || matchHasLivePublicId(matchData(mid))
          || (authed() && matchData(mid).createdBy == request.auth.uid)
          || matchRosterVisibleToAuth(mid)
          || matchParentSquadVisibleToAuth(mid)
        );
    }

    /** Signed-in user who created the match document. */
    function matchCreator(mid) {
      return authed()
        && exists(/databases/$(database)/documents/matches/$(mid))
        && matchData(mid).createdBy == request.auth.uid;
    }

    /** Tournament organiser (for cascade delete / listing linked matches). */
    function tournamentOrganiserForMatch(mid) {
      return authed()
        && exists(/databases/$(database)/documents/matches/$(mid))
        && matchData(mid).tournamentId != null
        && exists(/databases/$(database)/documents/tournaments/$(matchData(mid).tournamentId))
        && tournamentDoc(matchData(mid).tournamentId).data.createdBy == request.auth.uid;
    }

    /** Same as tournamentOrganiserForMatch but uses `resource` on the match document. */
    function tournamentOrganiserReadsThisMatch() {
      return authed()
        && resource.data.tournamentId != null
        && exists(/databases/$(database)/documents/tournaments/$(resource.data.tournamentId))
        && tournamentDoc(resource.data.tournamentId).data.createdBy == request.auth.uid;
    }

    function tournamentDoc(tid) {
      return get(/databases/$(database)/documents/tournaments/$(tid));
    }

    function tournamentExists(tid) {
      return exists(/databases/$(database)/documents/tournaments/$(tid));
    }

    function tournamentOwner(tid) {
      return authed()
        && tournamentExists(tid)
        && tournamentDoc(tid).data.createdBy == request.auth.uid;
    }

    function tournamentPublic(tid) {
      return tournamentExists(tid)
        && tournamentDoc(tid).data.isPublic == true;
    }

    /** teamCount is set only at create; updates must leave it unchanged (or absent on legacy docs). */
    function tournamentTeamCountImmutable() {
      return !resource.data.keys().hasAny(['teamCount'])
        ? !request.resource.data.keys().hasAny(['teamCount'])
        : request.resource.data.teamCount == resource.data.teamCount;
    }

    /** Squad doc must live under the organiser who links it into a tournament. */
    function userTeamDocExistsFor(uid, teamId) {
      return exists(/databases/$(database)/documents/users/$(uid)/teams/$(teamId));
    }

    /** Squad owner may maintain `users/{memberUid}/accessibleSquads` index rows for their team. */
    function squadOwnerMaintainsMemberAccessibleSquad(ownerUid, teamId) {
      return authed()
        && request.auth.uid == ownerUid
        && userTeamDocExistsFor(ownerUid, teamId);
    }

    function accessibleSquadRoleValid() {
      return request.resource.data.role == 'member'
        || request.resource.data.role == 'co-owner';
    }

    function accessibleSquadOwnerWrite() {
      return request.resource.data.ownerUid is string
        && request.resource.data.teamId is string
        && request.resource.data.teamName is string
        && accessibleSquadRoleValid()
        && squadOwnerMaintainsMemberAccessibleSquad(
          request.resource.data.ownerUid,
          request.resource.data.teamId,
        );
    }

    function userTeamData(uid, teamId) {
      return get(/databases/$(database)/documents/users/$(uid)/teams/$(teamId)).data;
    }

    function isUidInTeamOwnerIds(teamPathUid, teamId, memberUid) {
      return userTeamDocExistsFor(teamPathUid, teamId)
        && userTeamData(teamPathUid, teamId).keys().hasAny(['ownerIds'])
        && userTeamData(teamPathUid, teamId).ownerIds is list
        && memberUid in userTeamData(teamPathUid, teamId).ownerIds;
    }

    function isTeamCoOwner(uid, teamId) {
      return authed() && isUidInTeamOwnerIds(uid, teamId, request.auth.uid);
    }

    /** Primary owner on the roster cannot remove themselves via save. */
    function primaryOwnerCannotRemoveSelfFromRoster(teamPathUid) {
      return request.auth.uid != teamPathUid
        || !resource.data.keys().hasAny(['memberIds'])
        || !(request.auth.uid in resource.data.memberIds)
        || (
          request.resource.data.keys().hasAny(['memberIds'])
          && request.resource.data.memberIds is list
          && request.auth.uid in request.resource.data.memberIds
        );
    }

    function coOwnerCannotStripOwners(teamPathUid, teamId) {
      let prev = userTeamData(teamPathUid, teamId);
      let ownerList = prev.keys().hasAny(['ownerIds']) && prev.ownerIds is list
        ? prev.ownerIds
        : [];
      return request.resource.data.keys().hasAny(['memberIds'])
        && request.resource.data.memberIds is list
        && request.resource.data.memberIds.hasAll([teamPathUid])
        && request.resource.data.memberIds.hasAll(ownerList);
    }

    function coOwnerTeamUpdateAllowed(uid, teamId) {
      return isTeamCoOwner(uid, teamId)
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['ownerIds'])
        && coOwnerCannotStripOwners(uid, teamId);
    }

  /** Co-owner removes only themselves from ownerIds (evaluated against current team doc via get()). */
    function coOwnerSelfRemoveOwnerIds(teamPathUid, teamId) {
      return authed()
        && request.auth.uid != teamPathUid
        && isUidInTeamOwnerIds(teamPathUid, teamId, request.auth.uid)
        && request.resource.data.keys().hasAny(['ownerIds'])
        && request.resource.data.ownerIds is list
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ownerIds'])
        && !(request.auth.uid in request.resource.data.ownerIds);
    }

    function coOwnerSelfDemoteAccessibleSquad(userUid) {
      return authed()
        && request.auth.uid == userUid
        && resource.data.ownerUid is string
        && resource.data.teamId is string
        && resource.data.role == 'co-owner'
        && request.resource.data.role == 'member'
        && userTeamDocExistsFor(resource.data.ownerUid, resource.data.teamId);
    }

    function teamCoOwnerNotificationCreate(recipientUid) {
      return request.resource.data.type == 'team_co_owner'
        && request.resource.data.kind is string
        && request.resource.data.teamId is string
        && request.resource.data.teamName is string
        && request.resource.data.primaryOwnerUid is string
        && request.resource.data.otherUid is string
        && request.resource.data.createdAt is timestamp
        && (
          (
            request.resource.data.kind == 'co_owner_assigned'
            && request.auth.uid == request.resource.data.primaryOwnerUid
            && recipientUid != request.auth.uid
            && userTeamDocExistsFor(request.auth.uid, request.resource.data.teamId)
            && isUidInTeamOwnerIds(request.auth.uid, request.resource.data.teamId, recipientUid)
          )
          || (
            request.resource.data.kind == 'co_owner_left'
            && request.auth.uid == request.resource.data.otherUid
            && userTeamDocExistsFor(request.resource.data.primaryOwnerUid, request.resource.data.teamId)
            && (
              recipientUid == request.resource.data.primaryOwnerUid
              || recipientUid == request.resource.data.otherUid
            )
          )
          || (
            request.resource.data.kind == 'co_owner_removed'
            && request.auth.uid == request.resource.data.primaryOwnerUid
            && request.resource.data.otherUid == request.resource.data.primaryOwnerUid
            && recipientUid != request.auth.uid
            && recipientUid != request.resource.data.primaryOwnerUid
            && userTeamDocExistsFor(request.auth.uid, request.resource.data.teamId)
          )
        );
    }

    function teamRosterNotificationCreate(recipientUid) {
      return request.resource.data.type == 'team_roster'
        && request.resource.data.kind == 'removed_from_team'
        && request.resource.data.teamId is string
        && request.resource.data.teamName is string
        && request.resource.data.primaryOwnerUid is string
        && request.resource.data.actorUid is string
        && request.resource.data.createdAt is timestamp
        && recipientUid != request.auth.uid
        && request.auth.uid == request.resource.data.actorUid
        && userTeamDocExistsFor(request.resource.data.primaryOwnerUid, request.resource.data.teamId)
        && (
          request.auth.uid == request.resource.data.primaryOwnerUid
          || isTeamCoOwner(
            request.resource.data.primaryOwnerUid,
            request.resource.data.teamId,
          )
        );
    }

    function teamTransferData(transferId) {
      return get(/databases/$(database)/documents/teamOwnershipTransfers/$(transferId)).data;
    }

    function isTransferParty(transferId) {
      return authed()
        && exists(/databases/$(database)/documents/teamOwnershipTransfers/$(transferId))
        && (
          teamTransferData(transferId).fromUid == request.auth.uid
          || teamTransferData(transferId).toUid == request.auth.uid
        );
    }

    /** Primary owner sets pending transfer id on their team. */
    function ownerSetsPendingOwnershipTransfer(teamPathUid) {
      return authed()
        && request.auth.uid == teamPathUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingOwnershipTransferId'])
        && request.resource.data.keys().hasAny(['pendingOwnershipTransferId'])
        && request.resource.data.pendingOwnershipTransferId is string;
    }

    /** Primary owner clears pending transfer on their team (cancel / after resolve). */
    function ownerClearsPendingOwnershipTransfer(teamPathUid) {
      return authed()
        && request.auth.uid == teamPathUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingOwnershipTransferId'])
        && (
          !request.resource.data.keys().hasAny(['pendingOwnershipTransferId'])
          || request.resource.data.pendingOwnershipTransferId == null
        );
    }

    function ownershipTransferNotificationCreate(recipientUid) {
      return request.resource.data.type == 'ownership_transfer'
        && request.resource.data.kind is string
        && request.resource.data.teamId is string
        && request.resource.data.teamName is string
        && request.resource.data.transferId is string
        && request.resource.data.otherUid is string
        && request.resource.data.createdAt is timestamp
        && (
          isTransferParty(request.resource.data.transferId)
          || (
            request.resource.data.kind == 'transfer_received'
            && request.auth.uid == request.resource.data.otherUid
            && recipientUid != request.auth.uid
            && userTeamDocExistsFor(request.auth.uid, request.resource.data.teamId)
          )
          || (
            request.resource.data.kind == 'transfer_rejected'
            && request.auth.uid == request.resource.data.otherUid
            && recipientUid != request.auth.uid
            && exists(/databases/$(database)/documents/teamOwnershipTransfers/$(request.resource.data.transferId))
            && teamTransferData(request.resource.data.transferId).fromUid == recipientUid
            && teamTransferData(request.resource.data.transferId).toUid == request.auth.uid
          )
        );
    }

    /** Recipient of a pending ownership transfer (read/update sender team to resolve it). */
    function pendingTransferRecipientForTeam(teamPathUid, teamId) {
      return authed()
        && request.auth.uid != teamPathUid
        && resource.data.keys().hasAny(['pendingOwnershipTransferId'])
        && resource.data.pendingOwnershipTransferId is string
        && exists(/databases/$(database)/documents/teamOwnershipTransfers/$(resource.data.pendingOwnershipTransferId))
        && teamTransferData(resource.data.pendingOwnershipTransferId).fromUid == teamPathUid
        && teamTransferData(resource.data.pendingOwnershipTransferId).teamId == teamId
        && teamTransferData(resource.data.pendingOwnershipTransferId).toUid == request.auth.uid;
    }

    /** Transfer recipient may clear `pendingOwnershipTransferId` on the sender's team (reject / expire). */
    function transferRecipientClearsTeamPending(teamPathUid, teamId) {
      return pendingTransferRecipientForTeam(teamPathUid, teamId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingOwnershipTransferId'])
        && (
          !request.resource.data.keys().hasAny(['pendingOwnershipTransferId'])
          || request.resource.data.pendingOwnershipTransferId == null
        );
    }

    function accessibleSquadOwnerDelete() {
      return resource.data.ownerUid is string
        && resource.data.teamId is string
        && squadOwnerMaintainsMemberAccessibleSquad(
          resource.data.ownerUid,
          resource.data.teamId,
        );
    }

    /** New owner removes stale index rows after ownership transfer (former owner no longer has the team). */
    function newTeamOwnerClearsStaleAccessibleSquad() {
      return authed()
        && resource.data.ownerUid is string
        && resource.data.teamId is string
        && request.auth.uid != resource.data.ownerUid
        && userTeamDocExistsFor(request.auth.uid, resource.data.teamId)
        && !userTeamDocExistsFor(resource.data.ownerUid, resource.data.teamId);
    }

    function userTeamJoinInviteData(token) {
      return get(/databases/$(database)/documents/userTeamJoinInvites/$(token)).data;
    }

    /** Signed-in player may merge only profile mirror fields onto `playerCareerStats/{pid}` (doc id must match uid). */
    function careerSelfProfileWrite(pid) {
      return request.auth.uid == pid
        && string(request.resource.data.playerId) == string(pid)
        && (
          (
            !exists(/databases/$(database)/documents/playerCareerStats/$(pid))
            && request.resource.data.keys().hasOnly(['playerId', 'profileFullName', 'profileDisplayName', 'updatedAt'])
          )
          || (
            exists(/databases/$(database)/documents/playerCareerStats/$(pid))
            && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['profileFullName', 'profileDisplayName', 'updatedAt', 'playerId'])
          )
        );
    }

    /** Shareable join links under `userTeamJoinInvites/{token}` (token stored on `TeamDoc.joinInviteToken`). */
    match /userTeamJoinInvites/{token} {
      allow read: if authed();
      allow create: if authed()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.teamId is string
        && request.resource.data.teamName is string
        && request.resource.data.memberIds is list
        && exists(/databases/$(database)/documents/users/$(request.auth.uid)/teams/$(request.resource.data.teamId))
        && request.resource.data.createdAt is timestamp;
      allow update: if authed() && (
        resource.data.ownerUid == request.auth.uid
        || (
          resource.data.teamId is string
          && isTeamCoOwner(resource.data.ownerUid, resource.data.teamId)
        )
      );
      allow delete: if authed() && resource.data.ownerUid == request.auth.uid;
    }

    match /teamOwnershipTransfers/{transferId} {
      allow read: if authed() && (
        resource.data.fromUid == request.auth.uid
        || resource.data.toUid == request.auth.uid
      );
      allow create: if authed()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.teamId is string
        && request.resource.data.teamName is string
        && request.resource.data.teamSnapshot is map
        && request.resource.data.createdAt is timestamp
        && request.resource.data.expiresAt is timestamp
        && userTeamDocExistsFor(request.auth.uid, request.resource.data.teamId);
      allow update: if authed() && (
        (
          resource.data.toUid == request.auth.uid
          && resource.data.status == 'pending'
          && (
            (
              request.resource.data.status == 'accepted'
              && request.resource.data.expiresAt > request.time
            )
            || request.resource.data.status == 'rejected'
          )
        )
        || (
          resource.data.fromUid == request.auth.uid
          && resource.data.status == 'pending'
          && request.resource.data.status == 'cancelled'
        )
        || (
          (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid)
          && resource.data.status == 'pending'
          && request.resource.data.status == 'expired'
        )
      );
      allow delete: if false;
    }

    match /users/{uid} {
      allow read, write: if authed() && request.auth.uid == uid;

      match /teams/{teamId} {
        allow list: if authed() && request.auth.uid == uid;

        allow get: if authed() && request.auth.uid == uid
          || (
            authed()
            && resource.data.keys().hasAny(['ownerIds'])
            && resource.data.ownerIds is list
            && request.auth.uid in resource.data.ownerIds
          )
          || (
            authed()
            && resource.data.keys().hasAny(['memberIds'])
            && resource.data.memberIds is list
            && request.auth.uid in resource.data.memberIds
          )
          || (
            authed()
            && resource.data.keys().hasAny(['joinInviteToken'])
            && resource.data.joinInviteToken is string
            && exists(/databases/$(database)/documents/userTeamJoinInvites/$(resource.data.joinInviteToken))
            && userTeamJoinInviteData(resource.data.joinInviteToken).ownerUid == uid
            && userTeamJoinInviteData(resource.data.joinInviteToken).teamId == teamId
          )
          || pendingTransferRecipientForTeam(uid, teamId);

        allow create: if authed() && request.auth.uid == uid;
        allow delete: if authed() && request.auth.uid == uid
          || pendingTransferRecipientForTeam(uid, teamId);

        allow update: if ownerSetsPendingOwnershipTransfer(uid)
          || ownerClearsPendingOwnershipTransfer(uid)
          || (
            authed()
            && request.auth.uid == uid
            && primaryOwnerCannotRemoveSelfFromRoster(uid)
          )
          || transferRecipientClearsTeamPending(uid, teamId)
          || coOwnerTeamUpdateAllowed(uid, teamId)
          || coOwnerSelfRemoveOwnerIds(uid, teamId)
          || (
            authed()
            && request.auth.uid != uid
            && resource.data.keys().hasAny(['joinInviteToken'])
            && resource.data.joinInviteToken is string
            && exists(/databases/$(database)/documents/userTeamJoinInvites/$(resource.data.joinInviteToken))
            && userTeamJoinInviteData(resource.data.joinInviteToken).ownerUid == uid
            && userTeamJoinInviteData(resource.data.joinInviteToken).teamId == teamId
            && request.resource.data.joinInviteToken == resource.data.joinInviteToken
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players'])
            && request.resource.data.players.size() == resource.data.players.size() + 1
            && request.resource.data.players.size() <= 40
            && request.resource.data.players[resource.data.players.size()].playerId == request.auth.uid
            && request.resource.data.players[resource.data.players.size()].name is string
            && request.resource.data.players[resource.data.players.size()].name.size() > 0
          );
      }

      match /accessibleSquads/{docId} {
        allow read: if authed() && request.auth.uid == uid;
        allow create, update: if authed() && request.auth.uid == uid
          || accessibleSquadOwnerWrite()
          || coOwnerSelfDemoteAccessibleSquad(uid);
        allow delete: if authed() && request.auth.uid == uid
          || accessibleSquadOwnerDelete()
          || newTeamOwnerClearsStaleAccessibleSquad();
      }

      match /notifications/{notificationId} {
        allow read: if authed() && request.auth.uid == uid;
        allow create: if authed() && (
          request.auth.uid == uid
          || ownershipTransferNotificationCreate(uid)
          || teamCoOwnerNotificationCreate(uid)
          || teamRosterNotificationCreate(uid)
        );
        allow update: if authed()
          && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readAt']);
        allow delete: if authed() && (
          request.auth.uid == uid
          || (
            resource.data.keys().hasAny(['transferId'])
            && isTransferParty(resource.data.transferId)
            && resource.data.kind == 'transfer_received'
          )
        );
      }
    }

    /** Searchable display names for adding registered users to squads. */
    match /directoryUsers/{uid} {
      allow read: if authed();
      allow create, update: if authed() && request.auth.uid == uid;
      allow delete: if authed() && request.auth.uid == uid;
    }

    match /tournaments/{tid} {
      allow read: if resource.data.isPublic == true
        || (authed() && resource.data.createdBy == request.auth.uid);
      allow create: if authed()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.teamCount is int
        && request.resource.data.teamCount >= 2
        && request.resource.data.teamCount <= 64;
      allow update: if tournamentOwner(tid) && tournamentTeamCountImmutable();
      allow delete: if tournamentOwner(tid);

      match /linkedTeams/{linkId} {
        allow read: if tournamentPublic(tid) || tournamentOwner(tid);
        allow create: if tournamentOwner(tid)
          && request.resource.data.userTeamId is string
          && userTeamDocExistsFor(request.auth.uid, request.resource.data.userTeamId);
        allow update, delete: if tournamentOwner(tid);
      }

      match /groups/{gid} {
        allow read: if tournamentPublic(tid) || tournamentOwner(tid);
        allow create, update, delete: if tournamentOwner(tid);
      }

      match /teams/{teamId} {
        allow read: if tournamentPublic(tid) || tournamentOwner(tid)
          || (authed() && resource.data.organiserUid == request.auth.uid);
        allow create: if tournamentOwner(tid)
          && request.resource.data.organiserUid == tournamentDoc(tid).data.createdBy;
        allow update, delete: if tournamentOwner(tid)
          || (authed() && resource.data.organiserUid == request.auth.uid);
      }

      match /standings/{docId} {
        allow read: if tournamentPublic(tid) || tournamentOwner(tid);
        allow write: if tournamentOwner(tid);
      }

      match /stats/{docId} {
        allow read: if tournamentPublic(tid) || tournamentOwner(tid);
        allow write: if tournamentOwner(tid);
      }
    }

    match /matches/{mid} {
      /**
       * Public matches readable by anyone (for home listing & shared links).
       * Any match with a `publicId` is readable via `/live/:publicId` without sign-in.
       * Private listing: creator, tournament organiser, squad, or parent squad.
       */
      allow read: if resource.data.isPublic == true
        || matchHasLivePublicId(resource.data)
        || (authed() && resource.data.createdBy == request.auth.uid)
        || tournamentOrganiserReadsThisMatch()
        || matchRosterVisibleOnResource()
        || matchParentSquadVisibleOnResource();

      allow create: if authed() && request.resource.data.createdBy == request.auth.uid;

      allow update: if authed() && resource.data.createdBy == request.auth.uid;

      allow delete: if authed() && (
        resource.data.createdBy == request.auth.uid
        || (resource.data.tournamentId != null
            && exists(/databases/$(database)/documents/tournaments/$(resource.data.tournamentId))
            && tournamentDoc(resource.data.tournamentId).data.createdBy == request.auth.uid)
      );

      match /innings/{iid} {
        allow read: if canAccessMatchSubcollection(mid) || tournamentOrganiserForMatch(mid);
        allow create, update: if canAccessMatchSubcollection(mid);
        allow delete: if matchCreator(mid) || tournamentOrganiserForMatch(mid);
      }

      match /events/{eid} {
        allow read: if canAccessMatchSubcollection(mid) || tournamentOrganiserForMatch(mid);
        allow create: if authed() && matchData(mid).createdBy == request.auth.uid;
        allow update: if false;
        allow delete: if matchCreator(mid) || tournamentOrganiserForMatch(mid);
      }

      match /playerStats/{pid} {
        allow read: if canAccessMatchSubcollection(mid) || tournamentOrganiserForMatch(mid);
        allow create, update, delete: if matchCreator(mid);
      }
    }

    /**
     * Cross-match rollups (all completed XIs). Readable without auth so `/player/:uid` works when logged out
     * (mirrored names + aggregates are intended as shareable).
     */
    match /playerCareerStats/{pid} {
      allow read: if true;
      allow create, update: if authed() && (
        careerSelfProfileWrite(pid)
        || (
          request.resource.data.keys().hasAny(['sourceMatchId'])
          && request.resource.data.sourceMatchId is string
          && exists(/databases/$(database)/documents/matches/$(request.resource.data.sourceMatchId))
          && matchData(request.resource.data.sourceMatchId).createdBy == request.auth.uid
        )
        || (
          request.resource.data.keys().hasAny(['sourceTournamentId'])
          && request.resource.data.sourceTournamentId is string
          && tournamentExists(request.resource.data.sourceTournamentId)
          && tournamentDoc(request.resource.data.sourceTournamentId).data.createdBy == request.auth.uid
        )
      );
      allow delete: if false;
    }
  }
}
